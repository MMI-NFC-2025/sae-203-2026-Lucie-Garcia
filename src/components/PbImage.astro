---
import { pb } from "../../backend/backend.mjs";
const { record, field, alt, classImg, thumb = "800x800" } = Astro.props;

const imageFile = record?.[field];
const imageUrl = imageFile
	? pb.files.getURL(record, imageFile, { thumb })
	: null;
---

{imageUrl && (
	<img
		class={classImg}
		src={imageUrl}
		alt={alt || "photo"}
		loading="lazy"
		decoding="async"
	/>
)}
