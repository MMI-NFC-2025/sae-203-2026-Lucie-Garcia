---
import Layout from "../../layouts/Layout.astro";
import CardArtistes from "../../components/CardArtistes.astro";
import SearchIcon from "../../assets/icons/search.svg";

import { allArtistes } from "../../../backend/backend.mjs";

const artistes = await allArtistes();
---

<Layout>
    <div class="bg-grad-diagonal pb-10">
        <form class="flex justify-center px-6 pt-6">
            <label
                class="relative w-full h-18 max-lg:h-14 max-w-4xl"
                for="artist-search"
            >
                <SearchIcon
                    class="absolute left-5 top-1/2 h-6 w-6 -translate-y-1/2 text-blue-800"
                />
                <input
                    id="artist-search"
                    type="text"
                    placeholder="Rechercher un artiste..."
                    class="w-full h-18 max-lg:h-14 rounded-2xl border-2 border-blue-800 bg-white/85 py-7 pl-15 pr-8 text-2xl text-gray-900 placeholder:text-gray-300"
                />
            </label>
        </form>
        <div class="m-5 flex flex-wrap gap-3 align-middle justify-center">
            <button
                data-filter-day="1"
                class="day-filter bg-white p-2 px-4 rounded-4xl ring-1 ring-gray-500 text-gray-900 font-semibold"
                >Lundi</button
            >
            <button
                data-filter-day="2"
                class="day-filter bg-white p-2 px-4 rounded-4xl ring-1 ring-gray-500 text-gray-900 font-semibold"
                >Mardi</button
            >
            <button
                data-filter-day="3"
                class="day-filter bg-white p-2 px-4 rounded-4xl ring-1 ring-gray-500 text-gray-900 font-semibold"
                >Mercredi</button
            >
            <button
                data-filter-day="4"
                class="day-filter bg-white p-2 px-4 rounded-4xl ring-1 ring-gray-500 text-gray-900 font-semibold"
                >Jeudi</button
            >
        </div>
        <div
            class="gap-3 max-md:flex-col max-md:flex p-5 md:grid md:grid-cols-2 md:space-x-3 lg:grid lg:grid-cols-3 lg:space-x-3 lg:p-10"
        >
            {
                artistes.length > 0 ? (
                    artistes.map((artiste) => (
                        <div
                            class="artiste"
                            data-day={
                                artiste.date
                                    ? String(new Date(artiste.date).getDay())
                                    : "-1"
                            }
                        >
                            <CardArtistes {...artiste} />
                        </div>
                    ))
                ) : (
                    <p>Aucun événement à afficher.</p>
                )
            }
        </div>
    </div>
</Layout>
<script>
    //@ts-nocheck
    const dayButtons = document.querySelectorAll(".day-filter");
    const artistesCards = document.querySelectorAll(".artiste");
    let activeDay = null;

    const applyFilter = () => {
        artistesCards.forEach((artiste) => {
            const isVisible =
                activeDay === null || artiste.dataset.day === activeDay;
            artiste.style.display = isVisible ? "block" : "none";
        });

        dayButtons.forEach((button) => {
            const isActive = button.dataset.filterDay === activeDay;
            button.classList.toggle("bg-blue-200", isActive);
            button.classList.toggle("shadow-2xl", isActive);
            button.classList.toggle("bg-white", !isActive);
            button.classList.toggle("ring-1", !isActive);
            button.classList.toggle("text-gray-900", !isActive);
        });
    };

    dayButtons.forEach((button) => {
        button.addEventListener("click", () => {
            const clickedDay = button.dataset.filterDay;
            activeDay = activeDay === clickedDay ? null : clickedDay;
            applyFilter();
        });
    });
</script>
